# Database (required)
DATABASE_URL=postgresql://user:password@localhost:5432/lead_discovery

# Google Places API (required for discovery stage)
GOOGLE_PLACES_API_KEY=

# LLM extraction — choose one of the two options below:
#
# Option A: Anthropic API (cloud)
#   Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=
EXTRACTION_MODEL=claude-3-5-haiku-20241022
EXTRACTION_MAX_TOKENS=1024
#
# Option B: Ollama (local, takes priority over Anthropic if set)
#   Install Ollama at https://ollama.com, pull a model, then run:
#     OLLAMA_HOST=0.0.0.0 ollama serve   (to allow network access)
#   Set OLLAMA_BASE_URL to http://localhost:11434 for same-machine,
#   or http://<ip>:11434 for a model running on another machine.
OLLAMA_BASE_URL=
OLLAMA_MODEL=llama3.2

# Web search provider — choose one:
#
# Option A: DuckDuckGo (default, free, no key needed, ~10 results/query)
#   Nothing to configure — used automatically when SERPER_API_KEY is not set.
#
# Option B: Serper.dev (Google-backed, 100 results/query, much higher yield)
#   Sign up at https://serper.dev — free tier available, $50/mo for 50k queries.
SERPER_API_KEY=

# Hunter.io (optional — personal email discovery in the enrichment stage)
#   Sign up at https://hunter.io — free tier: 25 searches/month
#   Starter $49/mo = 500 searches, Growth $99/mo = 2500 searches
#   When set, enrichment queries Hunter's database for real personal/business
#   emails at each company's domain instead of only guessing via SMTP probing.
HUNTER_API_KEY=
# Minimum Hunter confidence score to store an email (0–100). Default 70.
# 90+ = highly reliable, 70–89 = usable but may have some bounces.
HUNTER_MIN_CONFIDENCE=70

# Directories (relative to project root — defaults shown)
DATA_DIR=data
PAGES_DIR=data/pages
LLM_RUNS_DIR=data/llm_runs

# Logging
LOG_LEVEL=INFO

# Google Places tuning
PLACES_RATE_LIMIT_DELAY=0.5
PLACES_MAX_PAGES=3

# Scraper tuning
SCRAPER_RATE_LIMIT_DELAY=1.0
SCRAPER_CONNECT_TIMEOUT=10.0
SCRAPER_READ_TIMEOUT=30.0
# Set to false to ignore robots.txt and fetch all publicly accessible pages.
# robots.txt is advisory only — not legally binding for publicly available data.
RESPECT_ROBOTS_TXT=true

# Export
EXPORT_DIR=data/exports
