# Database
DATABASE_URL=postgresql://user:password@localhost:5432/lead_discovery

# LLM provider (OpenAI-compatible)
LLM_API_KEY=
LLM_MODEL=gpt-4o

# Directories (relative to project root)
DATA_DIR=data
PAGES_DIR=data/pages
LLM_RUNS_DIR=data/llm_runs

# Logging
LOG_LEVEL=INFO

# Google Places API (required for discovery stage)
GOOGLE_PLACES_API_KEY=
PLACES_RATE_LIMIT_DELAY=0.5
PLACES_MAX_PAGES=3

# Scraper settings
SCRAPER_RATE_LIMIT_DELAY=1.0
SCRAPER_CONNECT_TIMEOUT=10.0
SCRAPER_READ_TIMEOUT=30.0

# Anthropic / Extraction settings
ANTHROPIC_API_KEY=your-key-here
EXTRACTION_MODEL=claude-3-5-haiku-20241022
EXTRACTION_MAX_TOKENS=1024

# Export settings
EXPORT_DIR=data/exports
